@model IEnumerable<ALAoun_Pos.Models.ClsUnits>; 

@{
    ViewData["Title"] = "الوحدات";
}
<div class="container mt-4">

    <div class="row mb-3 d-flex justify-content-between w-100">
        <div class="col-md-4 m-0">
             <h1 class="mb-4 text-center">الوحدات</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Units/Create" class="btn btn-primary">إضافة وحدة جديدة</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>اسم الوحدة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var  unit in Model)
                {
                    <tr>
                        <td>@unit.UnitId</td>
                        <td>@unit.UnitName</td>
                        <td>
                            <a href="/Units/Edit/@unit.UnitId" class="btn  btn-warning me-1">تعديل</a>
                            <a href="/Units/Details/@unit.UnitId" class="btn  btn-info me-1">التفاصيل</a>
                            <a href="/Units/Delete/@unit.UnitId" class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Units.js"></script>
}