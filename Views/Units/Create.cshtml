@{
    ViewData["Title"] = "وحدة قياس جديدة";
}


<div class="container mt-5">
    <h3>إضافة وحدة قياس جديدة</h3>
   
    <form id="createUnitForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="UnitName" class="form-label">اسم الوحدة</label>
            <input type="text" class="form-control fs-4" id="UnitName" name="UnitName" required>   
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ الوحدة</button>
            <a href="@Url.Action("Index", "Units")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>

@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Units.js"></script>
}