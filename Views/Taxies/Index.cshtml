@model IEnumerable<ALAoun_Pos.Models.ClsTaxies>; 

@{
    ViewData["Title"] = "الضرائب";
}
<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-md-4">
             <h1 class="mb-4 text-center">الضرائب</h1>
        </div>
        <div class="col-md-4">
        </div>
        <div class="col-md-4 text-end">
            <a href="/Taxies/Create" class="btn btn-primary">إضافة ضريبة جديدة</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>اسم الضريبة</th>
                    <th>نسبة الضريبة</th>
                    <th>الوصف</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var  tax in Model)
                {
                    <tr>
                        <td>@tax.taxId</td>
                        <td>@tax.taxName</td>
                        <td>@tax.taxRate</td>
                        <td>@tax.description</td>
                        <td>
                            <a href="/Taxies/Edit/@tax.taxId" class="btn  btn-warning me-1">تعديل</a>
                            <a href="/Taxies/Details/@tax.taxId" class="btn  btn-info me-1">التفاصيل</a>
                            <a href="/Taxies/Delete/@tax.taxId" class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @*
                 <tr>
                    <td colspan="8" class="text-center">
                        إجمالي الزبائن: @Model.Count
                    </td>
                </tr>
                *@

            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/Taxies.js"></script>
}