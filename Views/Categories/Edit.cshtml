@model ALAoun_Pos.Models.ClsCategories; 
@{
    ViewData["Title"] = "تعديل التصنيف";
}


<div class="container mt-5">
    <h3>تعديل التصنيف</h3>
   
    <form id="editCategoryForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="CategoryName" class="form-label">اسم التصنيف</label>
            <input type="text"
                   class="form-control fs-4" 
                   id="CategoryName" 
                   value="@Model.CategoryName"
                   name="CategoryName" required>   
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ التصنيف</button>
            <a href="@Url.Action("Index", "Categories")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>
@section scripts {
    <script src="~/JS/Categories.js"></script>
}