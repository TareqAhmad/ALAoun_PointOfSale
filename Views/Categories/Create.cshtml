@{
    ViewData["Title"] = "تصنيف جديد";
}


<div class="container mt-5">
    <h3>إضافة تصنيف جديد</h3>
   
    <form id="createCategoryForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="CategoryName" class="form-label">اسم التصنيف</label>
            <input type="text" class="form-control fs-4" id="CategoryName" name="CategoryName" required>   
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ التصنيف</button>
            <a href="@Url.Action("Index", "Categories")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>
@section scripts {
    <script src="~/JS/Categories.js"></script>
}