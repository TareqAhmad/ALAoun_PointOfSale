@model IEnumerable<ALAoun_Pos.Models.ClsCategories>; 

@{
    ViewData["Title"] = "اصناف المنتجات";
}
<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-md-4">
              <h1 class="mb-4 text-center">الاصناف</h1>
        </div>
        <div class="col-md-4">
        </div>
        <div class="col-md-4 text-end">
            <a href="/Categories/Create" class="btn btn-primary fs-5">إضافة صنف جديد</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>اسم الصنف</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>@category.CategoryId</td>
                        <td>@category.CategoryName</td>
    
                        <td>
                            <a href="/Categories/Edit/@category.CategoryId" class="btn  btn-warning me-1 ">تعديل</a>
                            <a href="/Categories/Details/@category.CategoryId" class="btn btn-info me-1">التفاصيل</a>
                            <a href="/Categories/Delete/@category.CategoryId" class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @*
                 <tr>
                    <td colspan="8" class="text-center">
                        إجمالي الزبائن: @Model.Count
                    </td>
                </tr>
                *@

            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/Categories.js"></script>
}