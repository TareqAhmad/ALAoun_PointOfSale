@{
    ViewData["Title"] = "زبون جديد";
}


<div class="container mt-5">
    <h3>إضافة زبون جديد</h3>
   
    <form id="createCustomerForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="CustomerName" class="form-label">اسم الزبون</label>
            <input type="text" class="form-control fs-4" id="CustomerName" name="CustomerName" required>   
        </div>
        <div class="mb-3">
            <label for="Phone" class="form-label">الهاتف</label>
            <input type="text" class="form-control fs-4" id="Phone" name="Phone" required>   
        </div>
        <div class="mb-3">
            <label for="Email" class="form-label">الإيميل</label>
            <input type="email" class="form-control fs-4" id="Email" name="Email" required>   
        </div>
         <div class="mb-3">
            <label for="Address" class="form-label">العنوان</label>
            <input type="text" class="form-control fs-4" id="Address" name="Address" required>   
        </div>
    
        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ الزبون</button>
            <a href="@Url.Action("Index", "Customers")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>
@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Customers.js"></script>
}