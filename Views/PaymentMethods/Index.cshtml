@model IEnumerable<ALAoun_Pos.Models.ClsPaymentMethods>; 

@{
    ViewData["Title"] = "طرق الدفع";
}
<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-md-4">
             <h1 class="mb-4 text-center">طرق الدفع</h1>
        </div>
        <div class="col-md-4">
        </div>
        <div class="col-md-4 text-end">
            <a href="/PaymentMethods/Create" class="btn btn-primary">إضافة طريقة دفع جديدة</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>نوع طريقة الدفع</th>
                     <th>وصف طريقة الدفع</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var paymentMethods in Model)
                {
                    <tr>
                        <td>@paymentMethods.PaymentId</td>
                        <td>@paymentMethods.PaymentType</td>
                        <td>@paymentMethods.Description</td>
   
                        <td>
                            <a href="/PaymentMethods/Edit/@paymentMethods.PaymentId" class="btn  btn-warning me-1">تعديل</a>
                            <a href="/PaymentMethods/Details/@paymentMethods.PaymentId" class="btn  btn-info me-1">التفاصيل</a>
                            <a href="/PaymentMethods/Delete/@paymentMethods.PaymentId " class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @*
                 <tr>
                    <td colspan="8" class="text-center">
                        إجمالي الزبائن: @Model.Count
                    </td>
                </tr>
                *@

            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/PaymentMethods.js"></script>
}