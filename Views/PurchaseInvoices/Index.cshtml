@model IEnumerable<ALAoun_Pos.Models.PurchaseInvoicesVM>

@{
    ViewData["Title"] = "فواتير المشتريات";
}

<div class="container mt-4">

    <h1 class="mb-4">فواتير المشتريات</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle p-3">
            <thead class="table-dark fs-5">
                <tr>
                    <th>رقم الفاتورة</th>
                    <th>تاريخ الفاتورة</th>
                    <th>نوع الفاتورة</th>
                    <th>طريقة الدفع</th>
                    <th>اسم المورد</th>
                    <th>قيمة الخصم<th>
                    <th>قيمة الضريبة</th>
                    <th>اجمالي</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var purchaseInvoices in Model)
                {
                    <tr>
                        <td>@purchaseInvoices.PurchaseId</td>
                        <td>@purchaseInvoices.PurchaseDate</td>
                        <td>@purchaseInvoices.InvoiceType</td>
                        <td>@purchaseInvoices.PaymentType</td>
                        <td>@purchaseInvoices.SupplierName</td>
                        <td>@purchaseInvoices.DiscountAmount.ToString("N3")</td>
                        <td>@purchaseInvoices.TaxAmount.ToString("N3")</td>
                        <td>@purchaseInvoices.NetAmount.ToString("N3")</td>
                        <td>
                            
                            <a href="/SalesInvoices/Details/@purchaseInvoices.PurchaseId" class="btn btn-sm btn-info me-1 fs-5">التفاصيل</a>
                           @*
                            <a href="#" class="btn btn-sm btn-warning me-1 fs-5">تعديل</a>
                            <a href="#" class="btn btn-sm btn-danger fs-5">حذف</a>
                           *@ 
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>
@section scripts {
    <script src="~/JS/PurchaseInvoices.js"></script>
}