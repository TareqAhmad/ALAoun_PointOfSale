@model IEnumerable<ALAoun_Pos.Models.ClsProducts>

@{
    ViewData["Title"] = "المنتجات";
}

<div class="container mt-4">

    <h1 class="mb-4">المنتجات</h1>
    <a id="btnAddProduct" href="/Products/Create" class="btn btn-primary mb-3 fs-5">إضافة منتج جديد</a>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle p-3">
            <thead class="table-dark fs-5">
                <tr>
                    <th>Barcode</th>
                    <th>اسم المنتج</th>
                    <th>التكلفة</th>
                    <th>سعر البيع</th>
                    <th>الكمية المتوفرة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Barcode</td>
                        <td>@product.ProductName</td>
                        <td>@product.ProductCost.ToString("N3")</td>
                        <td>@product.ProductPrice.ToString("N3")</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            <a href="/Products/Edit/@product.ProductId" class="btn btn-sm btn-warning me-1 fs-5">تعديل</a>
                            <a href="/Products/Details/@product.ProductId" class="btn btn-sm btn-info me-1 fs-5">التفاصيل</a>
                            <a href="/Products/Delete/@product.ProductId" class="btn btn-sm btn-danger fs-5">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>

@section scripts {
    <script src="~/JS/products.js"></script>
}