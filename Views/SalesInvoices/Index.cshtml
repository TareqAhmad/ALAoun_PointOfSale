@model IEnumerable<ALAoun_Pos.Models.SalesInvoiceVM>

@{
    ViewData["Title"] = "فواتير المبيعات";
}

<div class="container mt-4">

    <h1 class="mb-4">فواتير المبيعات</h1>

  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle p-3">
        <thead class="table-dark fs-5">
            <tr>
                <th>رقم الفاتورة</th>
                <th>تاريخ الفاتورة</th>
                <th>نوع الفاتورة</th>
                <th>طريقة الدفع</th>
                <th>اسم الزبون</th>
                <th>عدد المواد</th>
                <th>قيمة الخصم</th> <th>قيمة الضريبة</th>
                <th>إجمالي</th>
                <th>الصافي</th>
                <th>المستخدم</th>
                <th class="text-center">الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var salesInvoiceVM in Model)
            {
                <tr>
                    <td>@salesInvoiceVM.InvoiceId</td>
                    <td>@salesInvoiceVM.InvoiceDate.ToString("yyyy/MM/dd hh:mm tt")</td>
                    <td>@salesInvoiceVM.InvoiceType</td>
                    <td>@salesInvoiceVM.PaymentType</td>
                    <td>@salesInvoiceVM.CustomerName</td>
                    <td>@salesInvoiceVM.QuantityItems</td>
                    <td>@salesInvoiceVM.DiscountRate.ToString("N3")</td>
                    <td>@salesInvoiceVM.TaxRate.ToString("N3")</td>
                    <td>@salesInvoiceVM.TotalAmount.ToString("N3")</td>
                    <td class="fw-bold text-primary">@salesInvoiceVM.NetAmount.ToString("N3")</td>
                    <td>@salesInvoiceVM.userName</td>
                    <td class="text-center">
                        <a href="/SalesInvoices/Details/@salesInvoiceVM.InvoiceId" class="btn btn-sm btn-info fs-6">
                            <i class="bi bi-eye"></i> التفاصيل
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

</div>
@section scripts {
    <script src="~/JS/SalesInvoices.js"></script>
}