@model IEnumerable<ALAoun_Pos.Models.ClsUsers>

@{
    ViewData["Title"] = "المستخدمين";
}

<div class="container mt-5">
     
     <div class="row">
        <div class="col-md-7 d-flex justify-content-between align-items-center w-100">
                <h1 class="mb-4 ">المستخدمين</h1>
                <a id="btnAddProduct" href="/Users/Create" class="btn btn-primary mb-3 fs-5">إضافة مستخدم جديد</a>
        </div>


    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle p-3">
            <thead class="table-dark fs-5">
                <tr>
                    <th>اختيار</th>
                    <th>#</th>
                    <th>اسم المستخدم</th>
                    <th>الباسورد</th>
                    <th>رقم الهاتف</th>
                    <th>الايميل</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                       <td>
                          <input type="radio" name="userSelect" value="@user.UserId" class="user-radio" />
                        </td>
                        <td>@user.UserId</td>
                        <td>@user.UserName</td>
                        <td>@user.Password</td>
                        <td>@user.Phone</td>
                        <td>@user.Email</td>
                        <td>
                            <a href="/Users/Edit/@user.UserId" class="btn btn-sm btn-warning me-1 fs-5">تعديل</a>
                            <a href="/Users/Details/@user.UserId" class="btn btn-sm btn-info me-1 fs-5">التفاصيل</a>
                           @* <a href="/Users/Delete/@user.UserId" class="btn btn-sm btn-danger fs-5">حذف</a> *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-5 w-100" style="margin-top: 5rem;">
            <div id="privilegesContainer">
                <div class="alert alert-info">اختر مستخدماً لعرض صلاحياته</div>
            </div>
                <div class="table-responsive">
        <table class="table table-striped table-hover align-middle p-3">
            <thead class="table-dark fs-5">
                <tr>
                    <th>#</th>
                    <th>اسم الصلاحية</th>
                    <th>وصف الصلاحية</th> 
                    <th>تفعيل</th>
                </tr>
            </thead>
            <tbody id="privilegesTableBody">
            </tbody>
        </table>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/JS/apiService.js"></script>
    <script src="~/JS/Users.js"></script>
}