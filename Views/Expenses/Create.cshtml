@{
    ViewData["Title"] = "مصروف جديد";
}


<div class="container mt-5">
    <h3>إضافة مصروف جديد</h3>
   
    <form id="createProductForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="expenseDate" class="form-label">تاريخ المصروف</label>
            <input type="date" class="form-control fs-4" id="expenseDate" name="expenseDate" required>   
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">الوصف</label>
            <input type="text" class="form-control fs-4" id="description" name="description" required>   
        </div>
        <div class="mb-3">
            <label for="amount" class="form-label">المبلغ</label>
            <input type="number" class="form-control fs-4" id="amount" name="amount" step="0.01" required>   
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ المصروف</button>
            <a href="@Url.Action("Index", "Expenses")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>
@section scripts {
    <script src="~/JS/Expenses.js"></script>
}
