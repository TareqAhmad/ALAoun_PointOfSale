@model IEnumerable<ALAoun_Pos.Models.ClsExpenses>

@{
    ViewData["Title"] = "المصاريف";
}

<div class="container mt-4">

    <h1 class="mb-4"> المصاريف</h1>
    <div class="col-md-4 text-end">
       <a href="/Expenses/Create" class="btn btn-primary">إضافة مصاريف جديدة</a>
   </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle p-3">
            <thead class="table-dark fs-5">
                <tr>
                    <th>#</th>
                    <th>التاريخ</th>
                    <th>البيــــــان</th>
                    <th>المبلــغ</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in Model)
                {
                    <tr>
                        <td>@expense.expenseId</td>
                        <td>@expense.expenseDate</td>
                        <td>@expense.description</td>
                        <td>@expense.amount.ToString("N3")</td>
                        <td>
                            <a href="/Expenses/Details/@expense.expenseId" class="btn btn-sm btn-info me-1 fs-5">التفاصيل</a>
                            <a href="/Expenses/Edit/@expense.expenseId" class="btn btn-sm btn-warning me-1 fs-5">تعديل</a>
                            <a href="/Expenses/Delete/@expense.expenseId" class="btn btn-sm btn-danger fs-5">حذف</a>
                     
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>
@section scripts {
    <script src="~/JS/Expenses.js"></script>
}