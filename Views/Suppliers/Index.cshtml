@model IEnumerable<ALAoun_Pos.Models.ClsSuppliers>; 

@{
    ViewData["Title"] = "الموردين";
}
<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-md-4">
             <h1 class="mb-4 text-center">الموردين</h1>
        </div>
        <div class="col-md-4">
        </div>
        <div class="col-md-4 text-end">
            <a href="/Suppliers/Create" class="btn btn-primary">إضافة مورد جديد</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>اسم الزبون</th>
                    <th>الهاتف</th>
                    <th>الإيميل</th>
                    <th>العنوان</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var supplier in Model)
                {
                    <tr>
                        <td>@supplier.SupplierId</td>
                        <td>@supplier.SupplierName</td>
                        <td>@supplier.Phone</td>
                        <td>@supplier.Email</td>
                        <td>@supplier.Address</td>
                        <td>
                            <a href="/Suppliers/Edit/@supplier.SupplierId" class="btn  btn-warning me-1">تعديل</a>
                            <a href="/Suppliers/Details/@supplier.SupplierId" class="btn  btn-info me-1">التفاصيل</a>
                            <a href="/Suppliers/Delete/@supplier.SupplierId" class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @*
                 <tr>
                    <td colspan="8" class="text-center">
                        إجمالي الزبائن: @Model.Count
                    </td>
                </tr>
                *@

            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/Suppliers.js"></script>
}