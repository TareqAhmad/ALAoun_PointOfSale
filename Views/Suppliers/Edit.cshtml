@model ALAoun_Pos.Models.ClsSuppliers
@{
    ViewData["Title"] = "تعديل المورد";
}


<div class="container mt-5">
    <h3>تعديل المورد</h3>
   
    <form id="editSupplierForm" class="mt-3 border rounded p-3 "   >
        <div class="mb-3">
            <label for="SupplierName" class="form-label">اسم المورد</label>
            <input type="text" 
                    class="form-control fs-4" 
                    id="SupplierName"
                    name="SupplierName" 
                    value="@Model.SupplierName" 
                     required>   
        </div>
        <div class="mb-3">
            <label for="Phone" class="form-label">الهاتف</label>
            <input type="text"
                    class="form-control fs-4" 
                    id="Phone" 
                    name="Phone" 
                    value="@Model.Phone"
                    required>   
        </div>
        <div class="mb-3">
            <label for="Email" class="form-label">الإيميل</label>
            <input type="email" 
                    class="form-control fs-4" 
                    id="Email" 
                    name="Email" 
                    value="@Model.Email"
                    required>   
        </div>
         <div class="mb-3">
            <label for="Address" class="form-label">العنوان</label>
            <input type="text" 
                    class="form-control fs-4" 
                    id="Address" 
                    name="Address" 
                    value="@Model.Address"
                    required>   
        </div>
    
        <div class="mb-3">
            <button type="submit" class="btn btn-success fs-4">حفظ المورد</button>
            <a href="@Url.Action("Index", "Suppliers")" class="btn btn-secondary fs-4">إلغاء</a>
        </div>
    </form>    

</div>
@section scripts {
    <script src="~/JS/Suppliers.js"></script>
}