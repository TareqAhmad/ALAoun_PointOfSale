@model IEnumerable<ALAoun_Pos.Models.ClsDiscounts>; 

@{
    ViewData["Title"] = "الخصومات";
}
<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-md-4">
             <h1 class="mb-4 text-center">الخصومات</h1>
        </div>
        <div class="col-md-4">
        </div>
        <div class="col-md-4 text-end">
            <a href="/Discounts/Create" class="btn btn-primary">إضافة خصم جديد</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>الرقم</th>
                    <th>اسم الخصم</th>
                    <th>نوع الخصم</th>
                    <th>نسبة الخصم</th>
                    <th>تاريخ البدء</th>
                    <th>تاريخ الانتهاء</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var discount in Model)
                {
                    <tr>
                        <td>@discount.discountId</td>
                        <td>@discount.discountName</td>
                        <td>@discount.discountType</td>
                        <td>@discount.discountRate</td>
                        <td>@discount.startDate</td>
                        <td>@discount.endDate</td>
                        <td>
                            <a href="/Discounts/Edit/@discount.discountId" class="btn  btn-warning me-1">تعديل</a>
                            <a href="/Discounts/Details/@discount.discountId" class="btn  btn-info me-1">التفاصيل</a>
                            <a href="/Discounts/Delete/@discount.discountId" class="btn  btn-danger">حذف</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @*
                 <tr>
                    <td colspan="8" class="text-center">
                        إجمالي الزبائن: @Model.Count
                    </td>
                </tr>
                *@

            </tfoot>
        </table>
    </div>
</div>
@section scripts {
    <script src="~/JS/Discounts.js"></script>
}