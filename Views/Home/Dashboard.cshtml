@using ALAoun_Pos.Controllers
@{
    ViewData["Title"] = "لوحة التحكم";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Dashboard.css" />
}
 <div class="d-flex">        
        <nav class="sidebar bg-custom">
          <div class="sidebar-header p-3">
            <h2 class="text-white"> القائمة الرئيسية </h2>
          </div>
          <hr class="text-white">
          <ul class="list-unstyled ">
              <li><a href="#" class="active-link sidebar-link"><i class="bi bi-speedometer  fs-2 text-light"></i> الرئيسية </a></li>
              <li>
                  <a data-bs-toggle="collapse" href="#invoicesMenu" class="sidebar-link">
                      <i class="bi bi-file-earmark-text fs-2 text-danger"></i> الفواتير
                  </a>
                  <ul class="collapse list-unstyled" id="invoicesMenu">
                    <li><a href="@Url.Action("Index","SalesInvoices")">فواتير المبيعات </a></li>
                    <li><a href="@Url.Action("Index","SalesReturns")">مرتجع المبيعات</a></li> 
                    <li><a href="@Url.Action("Index","PurchaseInvoices")"> فواتير المشتريات</a></li> 
                    <li><a href="@Url.Action("Index","PurchasesReturns")">مرتجع المشتريات</a></li> 
                  </ul> 
              </li>
              
              <li>
                <a data-bs-toggle="collapse" href="#productsMenu" class="sidebar-link">
                    <i class="bi bi-box-seam fs-2 text-danger"></i> المنتجات
                </a>
                <ul class="collapse list-unstyled" id="productsMenu">
                  <li><a href="@Url.Action("Index","Categories")">التصنيفات </a></li>
                  <li><a href="@Url.Action("Index","Products")"> المنتجات</a></li>
                  <li><a href="@Url.Action("Index","StockMovements")"> المخزون </a></li>
                </ul>

             </li>
                 <li>
        <a data-bs-toggle="collapse" href="#peopleMenu" class="sidebar-link">
            <i class="bi bi-people fs-2 text-danger"></i> الاشخاص
        </a>

        <ul class="collapse list-unstyled ms-4" id="peopleMenu">
            <li><a href="@Url.Action("Index","Customers")">الزبائن</a></li>
            <li><a href="@Url.Action("Index","Suppliers")">الموردين</a></li>
        </ul>
    </li>
              
              <li><a href="@Url.Action("Index","Discounts")"><i class="bi bi-percent fs-2 text-danger"></i> الخصومات  </a></li>
              <li><a href="@Url.Action("Index","Taxies")"><i class="bi bi-calculator fs-2 text-danger"></i> الضرائب  </a></li>
              <li><a href="@Url.Action("Index","Expenses")"><i class="bi bi-receipt fs-2 text-danger"></i> المصاريف  </a></li>
              <li><a href="@Url.Action("Index","PaymentMethods")"><i class="bi bi-credit-card fs-2 text-danger"></i> طرق الدفع  </a></li>
              <hr class="text-white">
              <li>
                    <a data-bs-toggle="collapse" href="#branchesMenu" class="sidebar-link">
                       <i class="bi bi-geo-alt fs-2 text-danger"></i> إدارة الفروع
                   </a>
                   <ul class="collapse list-unstyled ms-4" id="branchesMenu">
                     <li><a href="@Url.Action("Index","Branches")">الفروع</a></li>
                     <li><a href="@Url.Action("Index","PosPoints")">نقاط البيع (الكاشير)</a></li>
                     <li><a href="@Url.Action("Index","Users")">المستخدمون والصلاحيات</a></li>
                   </ul>
                </li>
                <li><a href="#" class="sidebar-link"><i class="bi bi-gear me-2 fs-2 text-danger"></i> الاعدادات </a></li>
                <li><a href="/Home/index" class="sidebar-link"><i class="bi bi-box-arrow-right me-2 fs-2 text-danger"></i> الخروج</a></li>
          </ul>
        </nav>
        <main class="main-dashboard flex-grow-1 bg-dark text-light p-3 ">
            <h2 class="mt-5"> مرحباً بك في لوحة التحكم نظام العون</h2>
            <hr class="text-white">
            <div class="container-fluid mt-4 ">
                <div class="row g-3 mb-5 text-center">
                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-primary text-white rounded shadow-sm">
                            <i class="bi bi-cart-check-fill fs-1 mb-2"></i>
                            <div class="h6 fw-normal">إجمالي المبيعات</div>
                            <div class="h3 mb-0" id="totalSales">0.00</div>
                        </div>
                    </div>

                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-success text-white rounded shadow-sm">
                            <i class="bi bi-bag-plus-fill fs-1 mb-2"></i>
                            <div class="h6 fw-normal">المشتريات</div>
                            <div class="h3 mb-0" id="totalPurchases">0.00</div>
                        </div>
                    </div>

                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-warning text-dark rounded shadow-sm">
                            <i class="bi bi-cash-stack fs-1 mb-2"></i>
                            <div class="h6 fw-normal">المصاريف</div>
                            <div class="h3 mb-0" id="totalExpenses">0.00</div>
                        </div>
                    </div>

                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-danger text-white rounded shadow-sm">
                            <i class="bi bi-bank2 fs-1 mb-2"></i>
                            <div class="h6 fw-normal">النقدية بالصندوق</div>
                            <div class="h3 mb-0" id="netCash">0.00</div>
                        </div>
                    </div>
                </div>
              <hr class="text-white">
              <section class="text-light" id="section-content">
                 
              </section>
            </div>  
       </main>        
</div>
                
 @section scripts {
     <script src="~/JS/apiService.js"></script>
     <script src="~/JS/dashboard.js"></script>
 }
