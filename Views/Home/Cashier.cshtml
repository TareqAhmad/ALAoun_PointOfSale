
@{
    ViewData["Title"] = "الكاشير";
}

@section Styles {
    <style>
        body {
            background-color: #dfe6e9;
        }


    </style>
}

<div class="container  p-4">
    <div id="alert-container"></div>
     <div class="row bg-custom border-bottom border-white rounded mb-1">
        <div class="d-flex justify-content-around mb-1 p-3">
                <span class="fs-2 text-white"><i class="bi bi-cart-plus fs-2 text-danger"></i>شاشة الكاشير</span> 
                <span class="fs-2 text-white"><i class="bi bi-geo-alt-fill text-danger"></i>الفرع :  @ViewBag.branchName </span>
                <span class="fs-2 text-white"><i class="bi bi-person text-danger"></i>الكاشير : @ViewBag.userName </span>
                <span class="fs-2 text-white"><i class="bi bi-calendar-date fs-2 text-danger"></i> الوقت :   @DateTime.Now </span>
              
        </div>
     </div>
    <div class="d-flex gag-8 p-3" style="min-height: 80vh;">
        <!-- العمود الأول -->
            <div class="col bg-light border rounded shadow">
                <div class="d-flex flex-column h-100">
                        <div class="text-white" style="height :5rem;">
                            <div class="">
                                 <select class="form-select custom-select-rtl fs-4 p-4" id="Select-customer-cashier">
                                     <option value="" disabled selected>اختار الزبون</option>
                                     <option value="1"> الزبون</option>
                                 </select>
                            </div>
                        </div>
                        <div class="flex-grow-1  p-2 overflow-auto border-bottom border-secondary">
                                    <div class="d-flex flex-row-reverse gap-2 mt-2 border-bottom p-2">
                                        <button id="addPendingInvoice"  class="btn btn-light p-3 border rounded fs-1 fw-bold" style="width:10rem">Hold</button>
                                        <button id="btnEditQty"  data-bs-toggle="modal" data-bs-target="#editQtyModal" class="btn btn-light p-2 border rounded fs-2 fw-bold"  style="width:10rem">Edit Qty</button>
                                        <button id="btnDiscount" data-bs-toggle="modal" data-bs-target="#discountModal" class="btn btn-light p-2 border rounded fs-2 fw-bold"  style="width:10rem">Discount</button>
                                         <input type="text"  class="form-control fs-5" id="barcode" placeholder = "barcode"/>
                                   </div>
                                   <div class="table-responsive" style="max-height: 40rem; overflow-y:auto; ">
                                        <table class="table table-striped  text-center align-middle">
                                        <thead class="table-dark text-white" style="position: sticky;top:0;z-index:1;">
                                            <tr>
                                                <th class="text-danger">x</th>
                                                <th>#</th>
                                                <th class="text-end">المادة</th>
                                                <th>الكمية</th>
                                                <th>السعر</th>
                                                <th>المجموع</th>
                                            </tr>
                                        </thead>
                                        <tbody id="cartTableBody">
                                        </tbody>
                                        <tfoot></tfoot>
                                   </table>
                                   </div>

                        </div>
                        <div class="p-2" style="height :18rem;">
                             <div class="d-flex gap-2 border-bottom border-secondary p-2">
                                 <button id= "payInvoice" class="btn bg-success flex-fill p-3 text-white fw-bold">دفـــع</button>
                                 <button id="CancelCart" class="btn bg-danger  flex-fill p-3 text-white fw-bold" >الـــغــــاء</button>
                             </div>
                            <div class="d-flex flex-column gap-2 p-2">

                                <div class="d-flex justify-content-around border-bottom ">
                                    <h3 class="fs-4 fw-bold">المجموع</h3>
                                    <h3 class="fs-4 fw-bold" id="totalAmount">0.00</h3>
                                </div>

                                <div class="d-flex justify-content-around  border-bottom">
                                    <h3 class="fs-4 fw-bold">الخصم</h3>
                                    <h3 class="fs-4 fw-bold  me-3" id="discountAmount">0.00</h3>
                                </div>

                                <div class="d-flex justify-content-around  border-bottom">
                                    <h3 class="fs-4 fw-bold">الضريبة</h3>
                                    <h3 class="fs-4 fw-bold  me-1" id="taxAmount">0.00</h3>
                                </div>

                                <div class="d-flex justify-content-around">
                                    <h3 class="fs-4 fw-bold">الصافي</h3>
                                    <h3 class="fs-4 fw-bold me-1" id="netAmount">0.00</h3>
                                </div>

                            </div>                             

                        </div>
                </div>
           </div>
        <!-- العمود الثاني -->
        <div class="col bg-light border rounded shadow">
            <div class="d-flex flex-column h-100">
                <div class="d-flex flex-wrap gap-2 mb-3 p-4 border-bottom" id="categoryTabs" style="max-height: 20rem; overflow-y:auto; ">
                </div>                
                
                <div class="flex-fill p-1"  style="max-height: 50rem; overflow-y:auto; ">
                    <div id="cashier-products" class="d-flex flex-wrap gap-2"></div>
                </div>

              

            </div>
        </div>
    </div>
    <div class="container bg-light p-2 border rounded border-black text-center">
            
            <div class="d-flex justify-content-between" style="height :5rem;">
                      <a id="btn-hold" class="btn bg-custom rounded" data-bs-toggle="modal" data-bs-target="#holdModal" style="width:10rem;"><i class="bi bi-cart fs-1 text-danger"></i></a>
                      <a class="btn bg-custom rounded" style="width:10rem;"><i class="bi bi-gear fs-1 text-danger"></i></a>
                      <a id="GetSalesInvoices"  class="btn bg-custom rounded" style="width:10rem;"><i class="bi bi-receipt fs-1 text-danger"></i></a>
                      <a class="btn bg-custom rounded"  style="width:10rem;"><i class="bi bi-check-circle fs-1 text-danger"></i></a>
                      <a id="btn-Exit" href="@Url.Action("Index", "Home")" class="btn bg-custom rounded" style="width:10rem;"><i class="bi bi-box-arrow-right fs-1 text-danger"></i></a>                      
                </div>
    </div>
</div>



@*

   Modals 
*@



<div class="modal fade" id="holdModal" style="max-height: 70rem; overflow-y:auto">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg border-0">

            <div class="modal-header bg-custom d-flex flex-column align-items-stretch">
                <div class="d-flex justify-content-between align-items-center mb-3 w-100" dir="rtl">
                    <h3 class="modal-title text-white m-0">
                        <i class="bi bi-pause-circle ms-2"></i> الطلبات المعلقة
                    </h3>
                    <button type="button" class="btn-close btn-close-white m-0" data-bs-dismiss="modal"></button>
                </div>

                <div class="row g-2 bg-light p-2 rounded shadow-sm text-dark" dir="rtl">
                    <div class="col-8">
                        <input type="text" id="holdSearchTerm" class="form-control form-control-sm" placeholder="بحث برقم الطلب...">
                    </div>
                    <div class="col-4">
                        <button class="btn btn-primary btn-sm w-100" onclick="fetchPendingInvoices()">
                            <i class="bi bi-search"></i> تحديث
                        </button>
                    </div>
                </div>
            </div>

            <div id="hold-content" class="modal-body d-flex flex-wrap gap-2" style="max-height: 40rem; overflow-y:auto"> 
            </div>

            <div class="modal-footer bg-custom py-2 text-white d-flex justify-content-center">
                <h5 class="m-0"><i class="bi bi-info-circle me-1"></i> اختر طلباً لاسترجاعه للسلة</h5>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="editQtyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-custom text-white" dir="rtl">
                <h5 class="modal-title"><i class="bi bi-pencil-square ms-2"></i>تعديل الكمية</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center bg-light">
                <h4 id="editQtyProductName" class="text-secondary mb-3">اسم المنتج المختار</h4>
                <div class="input-group input-group-lg mb-3" dir="ltr">
                    <button class="btn btn-danger fs-2" onclick="changeQtyValue(-1)">-</button>
                    <input type="number" id="newQtyInput" class="form-control text-center fs-1 fw-bold border-custom" value="1">
                    <button class="btn btn-success fs-2" onclick="changeQtyValue(1)">+</button>
                </div>
                
                <div class="row g-2 mt-2">
                    @foreach (var num in new[] { "1", "2", "3", "4", "5", "6", "7", "8", "9", "0", "C" })
                    {
                        <div class="col-4">
                            <button class="btn btn-outline-dark w-100 py-3 fs-3 fw-bold" 
                                    onclick="numpadInput('@num')">@num</button>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-success btn-lg w-100 py-3 fw-bold" onclick="updateCartQuantity()">تـحـديـث</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="discountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg"> <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-custom text-white" dir="rtl">
                <h5 class="modal-title"><i class="bi bi-tag-fill ms-2"></i> تفاصيل تطبيق الخصم</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light text-end" dir="rtl">
                <div class="mb-3">
                    <label class="fw-bold mb-2">تطبيق الخصم على:</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="discountScope" id="scopeInvoice" checked onchange="refreshDiscountModalTable()">
                        <label class="btn btn-outline-primary py-2" for="scopeInvoice">كامل الفاتورة</label>
                        
                        <input type="radio" class="btn-check" name="discountScope" id="scopeItem" onchange="refreshDiscountModalTable()">
                        <label class="btn btn-outline-primary py-2" for="scopeItem" id="lblScopeItem">المادة المختارة</label>
                    </div>
                </div>

                <div class="table-responsive mb-3 border rounded bg-white" style="max-height: 200px;">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr>
                                <th>المادة</th>
                                <th class="text-center">الكمية</th>
                                <th class="text-center">السعر الحالي</th>
                            </tr>
                        </thead>
                        <tbody id="discountProductsTable">
                        </tbody>
                    </table>
                </div>

                <div class="row align-items-center">
                    <div class="col-md-6">
                         <label class="fw-bold mb-1">مبلغ الخصم (دينار):</label>
                         <div class="input-group input-group-lg">
                            <input type="number" id="discountInput" class="form-control text-center fw-bold border-primary" placeholder="0.000" step="0.01">
                            <span class="input-group-text bg-primary text-white">د.أ</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-white border rounded text-center">
                            <small class="text-muted d-block">إجمالي القيمة قبل الخصم</small>
                            <span id="amountBeforeDiscount" class="fs-4 fw-bold text-dark">0.000</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" onclick="applyDiscountAction()" class="btn btn-success px-5 fw-bold">تأكيد الخصم</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="payModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            
            <div class="modal-header bg-custom d-flex justify-content-between align-items-center w-100" dir="rtl">
                <h3 class="modal-title text-white m-0">
                    <i class="bi bi-cash-stack ms-2"></i> إتمام عملية الدفع
                </h3>
                <button type="button" class="btn-close btn-close-white m-0" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-0 bg-light" dir="rtl">
                <div class="p-4 bg-dark text-white text-center">
                    <label class="text-muted small">صافي الفاتورة المطلوب</label>
                    <h1 class="display-4 fw-bold mb-0">
                        <span id="payFinalAmount" class="text-warning">0.000</span> <small class="fs-4 text-warning">دينار</small>
                    </h1>
                </div>

                <div class="p-4">
                    <label class="fw-bold mb-3 text-secondary">طريقة السداد:</label>
                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="paymentMethod" id="payCash" checked>
                            <label class="btn btn-outline-primary w-100 py-3 fs-5" for="payCash">
                                <i class="bi bi-wallet2 d-block fs-3 mb-1"></i> نقداً
                            </label>
                        </div>
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="paymentMethod" id="payCard">
                            <label class="btn btn-outline-primary w-100 py-3 fs-5" for="payCard">
                                <i class="bi bi-credit-card d-block fs-3 mb-1"></i> بطاقة
                            </label>
                        </div>
                    </div>

                    <div class="card border-0 bg-white shadow-sm p-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">المبلغ الإجمالي:</span>
                            <span><span id="payTotalBefore">0.000</span> د.أ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>إجمالي الخصم (-) :</span>
                            <span><span id="payTotalDiscount">0.000</span> د.أ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-primary">
                            <span>إجمالي الضريبة (+) :</span>
                            <span><span id="payTotalTax">0.000</span> د.أ</span>
                        </div>
                        <hr class="my-2">
                        
                        <div class="row g-2 align-items-center mb-3">
                            <div class="col-5 text-muted fw-bold">المبلغ المستلم:</div>
                            <div class="col-7">
                                <div class="input-group">
                                    <input type="number" id="receivedAmount" class="form-control form-control-lg text-center fw-bold border-primary" placeholder="0.000">
                                    <span class="input-group-text bg-primary text-white">دينار</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded border border-dashed">
                            <span class="fw-bold text-secondary">المبلغ المتبقي (للزبون):</span>
                            <span class="fs-4 fw-bold text-success"><span id="changeAmount">0.000</span> <small class="fs-6">دينار</small></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer p-3 border-0 bg-light">
                <button type="button" class="btn btn-success btn-lg w-100 py-3 shadow fw-bold" onclick="confirmPayment()">
                    تأكيد عملية البيع والطباعة
                </button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="SalesInvoicesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content shadow-lg border-0">

            <div class="modal-header bg-custom text-white d-flex flex-column align-items-stretch">
                <div class="d-flex justify-content-between align-items-center mb-3 w-100" dir="rtl">
                    <h3 class="modal-title text-white m-0">
                        <i class="bi bi-grid-3x3-gap me-2"></i> سجل فواتير المبيعات
                    </h3>
                    <button type="button" class="btn-close btn-close-white m-0" data-bs-dismiss="modal"></button>
                </div>
                
                <div class="row g-2 bg-light p-3 rounded shadow-sm text-dark">
                    <div class="col-md-3">
                        <input type="text" id="salesSearchTerm" class="form-control" placeholder="رقم الفاتورة أو الزبون...">
                    </div>
                    <div class="col-md-3">
                        <input type="date" id="salesDateFrom" class="form-control" title="من تاريخ">
                    </div>
                    <div class="col-md-3">
                        <input type="date" id="salesDateTo" class="form-control" title="إلى تاريخ">
                    </div>
                    <div class="col-md-3 d-flex gap-1">
                        <button class="btn btn-primary flex-grow-1" onclick="fetchSalesInvoices()">
                            <i class="bi bi-search"></i> بحث
                        </button>
                        <button class="btn btn-outline-secondary" onclick="resetSalesFilter()">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="modal-body p-0" style="max-height: 40rem; overflow-y:auto">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr>
                                <th># رقم الفاتورة</th>
                                <th>التاريخ والوقت</th>
                                <th>اسم الزبون</th>
                                <th>طريقة الدفع</th>
                                <th>الصافي</th>
                                <th>المستخدم</th>
                                <th class="text-center">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="sales-grid-content">
                            </tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer bg-custom text-white d-flex justify-content-between py-2">
                <div class="small text-white">عدد السجلات: <span id="salesTotalCount" class="fw-bold text-white">0</span></div>
                <div class="fs-5 text-white">إجمالي الصافي: <span id="salesTotalSum" class="fw-bold text-warning">0.000</span></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickAddProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-custom d-flex flex-column">
               <div class="d-flex justify-content-between align-items-center mb-3 w-100 text-white" dir="rtl">
                  <h5 class="modal-title m-0">تعريف منتج جديد سريع</h5>
                  <button type="button" class="btn-close btn-close-white m-0" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">الباركود</label>
                    <input type="text" id="newProductBarcode" class="form-control" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">اسم المنتج</label>
                    <input type="text" id="newProductName" class="form-control" placeholder="أدخل اسم المنتج">
                </div>
                <div class="mb-3">
                    <label class="form-label">السعر</label>
                    <input type="number" id="newProductPrice" class="form-control" step="0.001">
                </div>
                <div class="mb-3">
                    <label class="form-label">التصنيف</label>
                    <select id="newProductCategory" class="form-select">
                        </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" onclick="saveQuickProduct()" class="btn btn-success">حفظ وإضافة للسلة</button>
            </div>
        </div>
    </div>
</div>

 @section scripts {
      <script src="~/JS/apiService.js"></script>
      <script src="~/JS/cashier.js"></script>

 }